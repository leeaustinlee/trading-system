# ──────────────────────────────────────────────
# Trading System — 環境變數範本
# 複製為 .env 並填入實際值，不要 commit .env
# ──────────────────────────────────────────────

# ── 資料庫 (必填) ──────────────────────────────
# local dev 預設 port 3330；正式環境改為 3306
DB_URL=jdbc:mysql://localhost:3330/trading_system?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Taipei
DB_USERNAME=root
DB_PASSWORD=replace_me

TRADING_TIMEZONE=Asia/Taipei

# ── LINE Notify ────────────────────────────────
# 本機開發設 false；正式環境設 true 並填 token
LINE_ENABLED=false
LINE_TOKEN=
LINE_NOTIFY_URL=https://notify-api.line.me/api/notify

# ── TAIFEX Open API ───────────────────────────
TAIFEX_BASE_URL=https://openapi.taifex.com.tw

# ── Claude / Anthropic API ────────────────────
# 本機開發設 false；正式環境設 true 並填 api-key
CLAUDE_ENABLED=false
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096
# Claude 研究輸出路徑（絕對路徑），例：/mnt/d/ai/stock/claude-research-latest.md
CLAUDE_RESEARCH_OUTPUT_PATH=

# ── scripts/load-local-seed.sh 用 ─────────────
MYSQL_BIN=/mnt/c/Program Files/MySQL/MySQL Server 8.0/bin/mysql.exe
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3330
MYSQL_USER=root
MYSQL_PASSWORD=replace_me
MYSQL_DB=trading_system
SEED_SQL_PATH=D:/ai/stock/trading-system/sql/local-seed-phase2.sql
